# Backend environment variables.
# On Cloud Run, set these with --set-env-vars (see DEPLOY.md).
# Locally, copy to .env and load, or export them in your shell.

# GCP project that owns the bucket + Firestore.
GCP_PROJECT_ID=your-gcp-project-id

# Private GCS bucket for uploaded file bytes (public access MUST be blocked).
GCS_BUCKET=your-project-uploads

# Invite-only allowlist — comma-separated verified emails.
ALLOWED_EMAILS=you@example.com,teammate@example.com

# Extra browser origins allowed to call the API (CORS).
# Localhost is included by default; any *.vercel.app is allowed automatically.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
