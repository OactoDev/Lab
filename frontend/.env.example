# Frontend environment variables.
# Copy to .env.local for local dev, or set in the Vercel dashboard.

# Backend API base URL (Cloud Run URL in production).
VITE_API_URL=http://localhost:8000

# Firebase web app config (Project settings -> Your apps -> Web app).
# These are NOT secrets, but security still comes from the backend
# allowlist + Firestore/Storage rules, not from hiding these.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
